const fmtM = n => { if(!n||isNaN(n))return'—'; n=+n; if(n>=1e6)return'$'+fmt(n/1e6,2)+'M'; if(n>=1e3)return'$'+fmt(n/1e3,1)+'K'; return'$'+fmt(n); };
