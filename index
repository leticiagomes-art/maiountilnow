    <div class="kpi yl"><div class="kpi-lbl">Projeção Mês Completo</div><div class="kpi-val">${fmtM(tv*PROJ)}</div><div class="kpi-sub warn">×3.87 extrapolado</div></div>
    <div class="kpi rd"><div class="kpi-lbl">Total Reembolsado</div><div class="kpi-val">${fmtM(tr)}</div><div class="kpi-sub crit">${(tr/tv*100).toFixed(1)}% das vendas</div></div>
    <div class="kpi gn"><div class="kpi-lbl">Chargeback</div><div class="kpi-val">$0</div><div class="kpi-sub ok">Janela 60d ainda aberta</div></div>
    <div class="kpi ${taxa_g>12?'rd':taxa_g>8?'yl':'gn'}"><div class="kpi-lbl">Taxa Geral Reimb.</div><div class="kpi-val">${taxa_g.toFixed(1)}%</div><div class="kpi-sub ${taxa_g>12?'crit':taxa_g>8?'warn':'ok'}">Benchmark ≤8%</div></div>
    <div class="kpi bl"><div class="kpi-lbl">Produtos Ativos</div><div class="kpi-val">${prods.length}</div><div class="kpi-sub">3 novos vs Abr</div></div>
  `;

  const maxV = Math.max(...prods.map(([,v])=>v.vendas));
  $('bars-vendas').innerHTML = prods.map(([nm,v])=>barRow(nm,v.vendas,maxV,'var(--blue)',fmtM(v.vendas)+' ('+v.orders+'ped)')).join('');

  const maxT = Math.max(...prods.map(([,v])=>v.taxa));
  $('bars-taxa').innerHTML = prods.sort((a,b)=>b[1].taxa-a[1].taxa).map(([nm,v])=>{
    const c = v.taxa>15?'var(--red)':v.taxa>8?'var(--yellow)':'var(--green)';
    return barRow(nm,v.taxa,maxT,c,v.taxa.toFixed(1)+'%');
  }).join('');

  const sorted = Object.entries(PROD_MAIO).sort((a,b)=>b[1].vendas-a[1].vendas);
  $('tbl-prod').innerHTML = sorted.map(([nm,v],i)=>{
    const t = v.taxa;
    const proj = v.vendas * PROJ;
    const isNew = !HIST[nm];
    return `<tr>
      <td class="bold">${nm}${isNew?'<span class="pill p-bl" style="margin-left:5px">NOVO</span>':''}</td>
      <td class="right mono">${fmtM(v.vendas)}</td>
      <td class="center">${v.orders}</td>
      <td class="right mono crit">${fmtM(v.reimb)}</td>
      <td class="center ${v.ref_orders>0?'warn':''}">${v.ref_orders}</td>
      <td class="center">—</td>
      <td class="center"><span class="pill ${t>15?'p-rd':t>8?'p-yl':t>5?'p-or':'p-gn'}">${t.toFixed(1)}%</span></td>
      <td class="right mono yl">${fmtM(proj)}</td>
      <td class="center">${pill(t)}</td>
    </tr>`;
  }).join('');

  const tv_total = Object.values(PROD_MAIO).reduce((s,v)=>s+v.vendas,0);
  const tr_total = Object.values(PROD_MAIO).reduce((s,v)=>s+v.reimb,0);
  const taxa_total = (tr_total/tv_total*100).toFixed(1);
  $('tbl-prod').innerHTML += `<tr style="background:var(--surface2);font-weight:700">
    <td>TOTAL</td>
    <td class="right mono">${fmtM(tv_total)}</td>
    <td class="center">${Object.values(PROD_MAIO).reduce((s,v)=>s+v.orders,0)}</td>
    <td class="right mono crit">${fmtM(tr_total)}</td>
    <td class="center warn">${Object.values(PROD_MAIO).reduce((s,v)=>s+v.ref_orders,0)}</td>
    <td class="center">—</td>
    <td class="center"><span class="pill ${+taxa_total>10?'p-yl':'p-gn'}">${taxa_total}%</span></td>
    <td class="right mono yl">${fmtM(tv_total*PROJ)}</td>
    <td class="center">—</td>
  </tr>`;
  setTimeout(animateBars,80);
}

// ═══ AFILIADOS ═══
function renderAfil() {
  const afils = Object.entries(AFIL_MAIO)
    .filter(([,v])=>v.vendas>0)
    .sort((a,b)=>b[1].vendas-a[1].vendas);

  const tv = afils.reduce((s,[,v])=>s+v.vendas,0);
  const tr = afils.reduce((s,[,v])=>s+v.reimb,0);
  const rq = afils.reduce((s,[,v])=>s+v.reimb_qtd,0);

  $('kpi-afil').innerHTML = `
    <div class="kpi bl"><div class="kpi-lbl">Afiliados com Vendas</div><div class="kpi-val">${afils.length}</div><div class="kpi-sub">01–08/05</div></div>
    <div class="kpi or"><div class="kpi-lbl">Volume Total</div><div class="kpi-val">${fmtM(tv)}</div><div class="kpi-sub">8 dias</div></div>
    <div class="kpi rd"><div class="kpi-lbl">Total Reembolsado</div><div class="kpi-val">${fmtM(tr)}</div><div class="kpi-sub crit">${rq} casos · ${(tv>0?tr/tv*100:0).toFixed(1)}%</div></div>
    <div class="kpi gn"><div class="kpi-lbl">Top Afiliado</div><div class="kpi-val">HelpGrid</div><div class="kpi-sub ok">${fmtM(AFIL_MAIO['HelpGrid Calls']?.vendas||0)} · 1.7% taxa</div></div>
    <div class="kpi yl"><div class="kpi-lbl">Afiliados Taxa >10%</div><div class="kpi-val">${afils.filter(([,v])=>(v.reimb/Math.max(v.vendas,1)*100)>10).length}</div><div class="kpi-sub warn">Requerem atenção</div></div>
  `;

  const topV = afils.slice(0,15);
  const maxV = topV[0]?.[1]?.vendas||1;
  $('bars-afil-vol').innerHTML = topV.map(([nm,v])=>barRow(nm,v.vendas,maxV,'var(--blue)',fmtM(v.vendas))).join('');

  const byTaxa = afils.filter(([,v])=>v.reimb_qtd>0).map(([nm,v])=>[nm,v,(v.reimb/Math.max(v.vendas,1)*100)]).sort((a,b)=>b[2]-a[2]).slice(0,15);
  const maxT = byTaxa[0]?.[2]||1;
  $('bars-afil-taxa').innerHTML = byTaxa.map(([nm,v,t])=>{
    const c=t>15?'var(--red)':t>8?'var(--yellow)':'var(--green)';
    return barRow(nm,t,maxT,c,t.toFixed(1)+'% ('+v.reimb_qtd+'x)');
  }).join('');

  $('tbl-afil').innerHTML = afils.map(([nm,v],i)=>{
    const t = (v.reimb/Math.max(v.vendas,1)*100);
    return `<tr>
      <td class="center" style="color:var(--t4)">${i+1}</td>
      <td class="bold">${nm}</td>
      <td class="right mono">${fmtM(v.vendas)}</td>
      <td class="center">${v.orders}</td>
      <td class="center ${v.reimb_qtd>0?'warn':''}">${v.reimb_qtd}</td>
      <td class="right mono crit">${v.reimb>0?fmtM(v.reimb):'—'}</td>
      <td class="center"><span class="pill ${t>15?'p-rd':t>8?'p-yl':t>3?'p-or':'p-gn'}">${t.toFixed(1)}%</span></td>
      <td class="center">${pill(t)}</td>
    </tr>`;
  }).join('');
}

// ═══ TENDÊNCIA ═══
function renderTrend() {
  const MAR_TOTAL = {v:2715255, r:343649, cb:18738};
  const ABR_TOTAL = {v:2434052, r:351361, cb:16301};
  const MAI_TOTAL = {v:505139, r:28717, cb:0};
  const MAI_PROJ  = {v:MAI_TOTAL.v*PROJ, r:MAI_TOTAL.r*PROJ, cb:0};

  const t_mar = (MAR_TOTAL.r+MAR_TOTAL.cb)/MAR_TOTAL.v*100;
  const t_abr = (ABR_TOTAL.r+ABR_TOTAL.cb)/ABR_TOTAL.v*100;
  const t_mai = MAI_TOTAL.r/MAI_TOTAL.v*100;

  $('kpi-trend').innerHTML = `
    <div class="kpi bl"><div class="kpi-lbl">Março 2026 — Total</div><div class="kpi-val">${fmtM(MAR_TOTAL.v)}</div><div class="kpi-sub crit">Taxa: ${t_mar.toFixed(1)}%</div></div>
    <div class="kpi yl"><div class="kpi-lbl">Abril 2026 — Total</div><div class="kpi-val">${fmtM(ABR_TOTAL.v)}</div><div class="kpi-sub crit">Taxa: ${t_abr.toFixed(1)}%</div></div>
    <div class="kpi gn"><div class="kpi-lbl">Maio 2026 — 8 dias</div><div class="kpi-val">${fmtM(MAI_TOTAL.v)}</div><div class="kpi-sub ok">Taxa: ${t_mai.toFixed(1)}% (CB ainda aberto)</div></div>
    <div class="kpi or"><div class="kpi-lbl">Maio Projetado</div><div class="kpi-val">${fmtM(MAI_PROJ.v)}</div><div class="kpi-sub yl">×3.87 · vs Abr: ${((MAI_PROJ.v-ABR_TOTAL.v)/ABR_TOTAL.v*100).toFixed(0)}%</div></div>
    <div class="kpi ${t_mai<t_abr?'gn':'rd'}"><div class="kpi-lbl">Tendência Taxa Reimb.</div><div class="kpi-val">${t_mai.toFixed(1)}%</div><div class="kpi-sub ${t_mai<t_abr?'ok':'crit'}">vs Abr ${t_abr.toFixed(1)}%: ${t_mai<t_abr?'▼ Melhora':'▲ Piora'}</div></div>
  `;

  const all_prods = new Set([...Object.keys(HIST), ...Object.keys(PROD_MAIO)]);
  const prod_rows = [...all_prods].map(nm => {
    const h = HIST[nm]||{marco:{v:0,r:0,cb:0},abril:{v:0,r:0,cb:0}};
    const mai = PROD_MAIO[nm]||{vendas:0,reimb:0,cb:0,taxa:0};
    const t_mar = h.marco.v>0?(h.marco.r+h.marco.cb)/h.marco.v*100:0;
    const t_abr = h.abril.v>0?(h.abril.r+h.abril.cb)/h.abril.v*100:0;
    const t_mai = mai.taxa||0;
    const mai_proj = mai.vendas*PROJ;
    return {nm, h, mai, t_mar, t_abr, t_mai, mai_proj};
  }).sort((a,b) => b.mai.vendas - a.mai.vendas);

  $('tbl-trend').innerHTML = prod_rows.map(p => {
    const trend = trendArrow(p.t_abr, p.t_mai);
    const isNew = !HIST[p.nm];
    return `<tr>
      <td class="bold">${p.nm}${isNew?'<span class="pill p-bl" style="margin-left:4px">NOVO</span>':''}</td>
      <td class="right mono">${p.h.marco.v>0?fmtM(p.h.marco.v):'—'}</td>
      <td class="center"><span class="pill ${p.t_mar>15?'p-rd':p.t_mar>8?'p-yl':'p-gn'}">${p.h.marco.v>0?p.t_mar.toFixed(1)+'%':'—'}</span></td>
      <td class="right mono">${p.h.abril.v>0?fmtM(p.h.abril.v):'—'}</td>
      <td class="center"><span class="pill ${p.t_abr>15?'p-rd':p.t_abr>8?'p-yl':'p-gn'}">${p.h.abril.v>0?p.t_abr.toFixed(1)+'%':'—'}</span></td>
      <td class="right mono yl">${fmtM(p.mai_proj)}</td>
      <td class="center"><span class="pill ${p.t_mai>15?'p-rd':p.t_mai>8?'p-yl':p.t_mai>0?'p-gn':'p-bl'}">${p.mai.vendas>0?p.t_mai.toFixed(1)+'%':'—'}</span></td>
      <td class="center">${p.mai.vendas>0&&p.h.abril.v>0?trend:'—'}</td>
    </tr>`;
  }).join('');

  // Taxa bars per product
  const taxaBars = prod_rows.filter(p=>p.mai.vendas>0).sort((a,b)=>b.t_mai-a.t_mai);
  const maxTaxa = Math.max(...taxaBars.map(p=>Math.max(p.t_mar,p.t_abr,p.t_mai)),1);
  $('bars-trend-taxa').innerHTML = taxaBars.map(p => {
    const w_mar = (p.t_mar/maxTaxa*100).toFixed(1);
    const w_abr = (p.t_abr/maxTaxa*100).toFixed(1);
    const w_mai = (p.t_mai/maxTaxa*100).toFixed(1);
    return `<div style="padding:6px 0;border-bottom:1px solid var(--border-s)">
      <div style="font-size:11px;color:var(--t2);margin-bottom:4px;font-weight:600">${p.nm}</div>
      <div style="display:flex;gap:4px;align-items:center;margin-bottom:2px">
        <div style="width:40px;font-size:9px;color:var(--t4)">Mar</div>
        <div style="flex:1;height:5px;background:var(--surface2);border-radius:3px;overflow:hidden">
          <div class="bar-fill" data-pct="${w_mar}" style="background:var(--blue);height:5px;border-radius:3px"></div>
        </div>
        <div style="width:35px;text-align:right;font-size:9px;color:var(--blue)">${p.t_mar.toFixed(1)}%</div>
      </div>
      <div style="display:flex;gap:4px;align-items:center;margin-bottom:2px">
        <div style="width:40px;font-size:9px;color:var(--t4)">Abr</div>
        <div style="flex:1;height:5px;background:var(--surface2);border-radius:3px;overflow:hidden">
          <div class="bar-fill" data-pct="${w_abr}" style="background:var(--yellow);height:5px;border-radius:3px"></div>
        </div>
        <div style="width:35px;text-align:right;font-size:9px;color:var(--yellow)">${p.t_abr.toFixed(1)}%</div>
      </div>
      <div style="display:flex;gap:4px;align-items:center">
        <div style="width:40px;font-size:9px;color:var(--t4)">Mai</div>
        <div style="flex:1;height:5px;background:var(--surface2);border-radius:3px;overflow:hidden">
          <div class="bar-fill" data-pct="${w_mai}" style="background:${p.t_mai<p.t_abr?'var(--green)':p.t_mai>p.t_abr?'var(--red)':'var(--orange)'};height:5px;border-radius:3px"></div>
        </div>
        <div style="width:35px;text-align:right;font-size:9px;color:${p.t_mai<p.t_abr?'var(--green)':p.t_mai>p.t_abr?'var(--red)':'var(--t4)'}">${p.t_mai.toFixed(1)}%</div>
      </div>
    </div>`;
  }).join('');

  // Insights
  const improving = prod_rows.filter(p=>p.mai.vendas>0&&p.h.abril.v>0&&p.t_mai<p.t_abr-2);
  const worsening = prod_rows.filter(p=>p.mai.vendas>0&&p.h.abril.v>0&&p.t_mai>p.t_abr+2);
  const newProds = prod_rows.filter(p=>!HIST[p.nm]&&p.mai.vendas>0);
  $('insights').innerHTML = `
    ${improving.length?`<div style="margin-bottom:12px"><div style="font-size:11px;font-weight:700;color:var(--green);margin-bottom:6px">✅ Melhorando em Maio (taxa ↓):</div>
    ${improving.map(p=>`<div style="font-size:10px;color:var(--t2);padding:3px 0">• <strong>${p.nm}</strong>: ${p.t_abr.toFixed(1)}% → ${p.t_mai.toFixed(1)}% (▼${(p.t_abr-p.t_mai).toFixed(1)}pp)</div>`).join('')}</div>`:''}
    ${worsening.length?`<div style="margin-bottom:12px"><div style="font-size:11px;font-weight:700;color:var(--red);margin-bottom:6px">⚠️ Piorando em Maio (taxa ↑):</div>
    ${worsening.map(p=>`<div style="font-size:10px;color:var(--t2);padding:3px 0">• <strong>${p.nm}</strong>: ${p.t_abr.toFixed(1)}% → ${p.t_mai.toFixed(1)}% (▲${(p.t_mai-p.t_abr).toFixed(1)}pp)</div>`).join('')}</div>`:''}
    ${newProds.length?`<div style="margin-bottom:12px"><div style="font-size:11px;font-weight:700;color:var(--blue);margin-bottom:6px">🆕 Novos em Maio:</div>
    ${newProds.map(p=>`<div style="font-size:10px;color:var(--t2);padding:3px 0">• <strong>${p.nm}</strong>: ${fmtM(p.mai.vendas)} (${p.t_mai.toFixed(1)}% taxa)</div>`).join('')}</div>`:''}
    <div style="padding:8px;background:var(--yellow-l);border-radius:6px;font-size:10px;color:var(--yellow);border:1px solid rgba(245,158,11,.2)">
      ⚠️ <strong>AudiLeaf</strong> domina Maio com ${fmtM(PROD_MAIO['AudiLeaf']?.vendas||0)} (27% do volume total) mas taxa de 10.5% — monitorar.
    </div>`;
  setTimeout(animateBars,100);
}

window.addEventListener('DOMContentLoaded', () => {
  renderProd();
  renderAfil();
  renderTrend();
  setTimeout(animateBars,200);
});
</script>
</body>
</html>
