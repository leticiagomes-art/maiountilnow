<style>
:root{
  --bg:#0D0F14;--surface:#161920;--surface2:#1E2230;--surface3:#252A3A;
  --border:#2A2E3E;--border-s:rgba(255,255,255,.07);
  --t1:#F0F2F8;--t2:#B8BFCE;--t3:#7A8299;--t4:#4A5068;
  --orange:#FF6B35;--orange-glow:rgba(255,107,53,.25);
  --green:#22C55E;--green-l:rgba(34,197,94,.08);
  --blue:#3D8EFF;--blue-l:rgba(61,142,255,.08);
  --yellow:#F59E0B;--yellow-l:rgba(245,158,11,.08);
  --red:#EF4444;--red-l:rgba(239,68,68,.08);
  --purple:#A855F7;
  --font:'Inter',system-ui,sans-serif;--mono:'JetBrains Mono','Fira Code',monospace;
  --radius:10px;--radius-lg:14px;--shadow:0 2px 12px rgba(0,0,0,.4);
}
:root[data-theme="light"]{
  --bg:#F4F6FB;--surface:#FFFFFF;--surface2:#F0F2F8;--surface3:#E8EBF4;
  --border:#DDE1EE;--border-s:rgba(0,0,0,.07);
  --t1:#0D0F14;--t2:#3A4055;--t3:#6B738A;--t4:#9CA3B8;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);background:var(--bg);color:var(--t1);font-size:13px;line-height:1.5}
.hdr{background:var(--surface);border-bottom:1px solid var(--border);padding:0 28px;position:sticky;top:0;z-index:100}
.hdr-top{display:flex;align-items:flex-start;justify-content:space-between;padding:12px 0 8px;gap:12px;flex-wrap:wrap}
.brand{display:flex;align-items:center;gap:10px}
.brand-ico{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--orange),#ff9a00);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;box-shadow:0 2px 10px var(--orange-glow)}
.brand-name{font-size:15px;font-weight:800;color:var(--t1);letter-spacing:-.4px}
.brand-sub{font-size:9px;color:var(--t3);letter-spacing:.2px}
.hdr-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-top:4px}
.live-dot::before{content:'';display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--green);margin-right:5px;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.live-dot{font-size:10px;color:var(--t3);display:flex;align-items:center}
.badge{padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;white-space:nowrap}
.bdg-or{background:rgba(255,107,53,.15);color:var(--orange);border:1px solid rgba(255,107,53,.3)}
.bdg-gn{background:var(--green-l);color:var(--green);border:1px solid rgba(34,197,94,.25)}
.bdg-bl{background:var(--blue-l);color:var(--blue);border:1px solid rgba(61,142,255,.25)}
.bdg-yl{background:var(--yellow-l);color:var(--yellow);border:1px solid rgba(245,158,11,.25)}
.bdg-rd{background:var(--red-l);color:var(--red);border:1px solid rgba(239,68,68,.25)}
.theme-toggle{display:flex;align-items:center;gap:6px;padding:5px 10px;border:1px solid var(--border-s);border-radius:8px;background:var(--surface2);cursor:pointer;font-size:11px;color:var(--t2);font-family:var(--font)}
.tabs{display:flex;gap:2px;overflow-x:auto;padding-bottom:0}
.tab{padding:9px 16px;font-size:12px;font-weight:600;color:var(--t3);border-radius:8px 8px 0 0;cursor:pointer;transition:all .15s;border:1px solid transparent;border-bottom:none;bottom:-1px;position:relative;white-space:nowrap;display:flex;align-items:center;gap:6px}
.tab:hover{color:var(--t1);background:var(--surface2)}
.tab.active{color:var(--t1);background:var(--bg);border-color:var(--border);border-bottom-color:var(--bg);font-weight:700}
.tab-ico{width:20px;height:20px;border-radius:5px;background:var(--surface3);display:flex;align-items:center;justify-content:center;font-size:12px}
.body{padding:20px 28px 48px;max-width:1600px;margin:0 auto}
.sec{display:none}.sec.active{display:block}
.kpi-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:10px;margin-bottom:14px}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:13px 15px;position:relative;overflow:hidden}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.kpi.yl::before{background:var(--yellow)}.kpi.rd::before{background:var(--red)}.kpi.gn::before{background:var(--green)}.kpi.bl::before{background:var(--blue)}.kpi.or::before{background:var(--orange)}
.kpi-lbl{font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px}
.kpi-val{font-size:22px;font-weight:800;letter-spacing:-1px;line-height:1;color:var(--t1);font-family:var(--font)}
.kpi-sub{font-size:10px;color:var(--t4);margin-top:3px}
.kpi-sub.ok{color:var(--green)}.kpi-sub.warn{color:var(--yellow)}.kpi-sub.crit{color:var(--red)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px 18px;margin-bottom:12px}
.card.gfull{grid-column:1/-1}
.card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px}
.card-ttl{font-size:12px;font-weight:700;color:var(--t1);display:flex;align-items:center;gap:6px}
table{width:100%;border-collapse:collapse;font-size:11px}
thead th{text-align:left;padding:7px 10px;background:var(--surface2);color:var(--t3);font-size:9px;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid var(--border);white-space:nowrap}
tbody td{padding:7px 10px;border-bottom:1px solid var(--border-s);color:var(--t2)}
tbody tr:last-child td{border-bottom:none}
tbody tr:hover{background:var(--surface2)}
.bold{font-weight:700;color:var(--t1)!important}
.center{text-align:center}.right{text-align:right}
.mono{font-family:var(--mono)}
.ok{color:var(--green)!important}.warn{color:var(--yellow)!important}.crit{color:var(--red)!important}.bl{color:var(--blue)!important}.or{color:var(--orange)!important}
.bar-row{display:flex;align-items:center;gap:10px;padding:5px 0;border-bottom:1px solid var(--border-s)}
.bar-lbl{width:170px;font-size:11px;color:var(--t2);flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bar-track{flex:1;height:8px;background:var(--surface2);border-radius:4px;overflow:hidden}
.bar-fill{height:8px;border-radius:4px;width:0;transition:width .9s ease}
.bar-val{width:80px;font-size:10px;font-family:var(--mono);text-align:right;color:var(--t3);flex-shrink:0}
.pill{padding:2px 7px;border-radius:20px;font-size:9px;font-weight:700;white-space:nowrap}
.p-gn{background:var(--green-l);color:var(--green)}.p-rd{background:var(--red-l);color:var(--red)}.p-yl{background:var(--yellow-l);color:var(--yellow)}.p-bl{background:var(--blue-l);color:var(--blue)}.p-or{background:rgba(255,107,53,.12);color:var(--orange)}
.note-box{padding:10px 14px;border-radius:8px;font-size:11px;margin-bottom:14px;border:1px solid var(--border)}
.note-box.warn{background:var(--yellow-l);border-color:rgba(245,158,11,.3);color:var(--yellow)}
.note-box.info{background:var(--blue-l);border-color:rgba(61,142,255,.3);color:var(--blue)}
.trend-up{color:var(--green)}.trend-dn{color:var(--red)}.trend-ne{color:var(--t4)}
.cmp-bar{height:6px;border-radius:3px;margin-top:2px}
footer{text-align:center;padding:24px;font-size:10px;color:var(--t4);border-top:1px solid var(--border)}
@media(max-width:900px){.body,.hdr{padding-left:14px;padding-right:14px}.g2,.g3{grid-template-columns:1fr}.kpi-row{grid-template-columns:1fr 1fr}}
</style>
</head>
