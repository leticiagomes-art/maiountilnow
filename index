function animateBars(){
  document.querySelectorAll('.bar-fill[data-pct]').forEach(el=>{el.style.width=(el.dataset.pct||0)+'%';});
}
function barRow(label, val, maxVal, color, extra='') {
  const p = maxVal>0?Math.min((val/maxVal)*100,100):0;
  return `<div class="bar-row">
    <div class="bar-lbl" title="${label}">${label}</div>
    <div class="bar-track"><div class="bar-fill" data-pct="${p.toFixed(1)}" style="background:${color}"></div></div>
    <div class="bar-val">${extra||fmtM(val)}</div>
  </div>`;
}
function pill(taxa){
  if(taxa>20) return '<span class="pill p-rd">⛔ CRÍTICO</span>';
  if(taxa>15) return '<span class="pill p-rd">🚨 ALTO</span>';
  if(taxa>10) return '<span class="pill p-yl">⚠️ ATENÇÃO</span>';
  if(taxa>6)  return '<span class="pill p-or">👁️ MONIT.</span>';
  return '<span class="pill p-gn">✅ OK</span>';
}
function trendArrow(old_taxa, new_taxa){
  const diff = new_taxa - old_taxa;
  if(diff > 2) return `<span class="trend-dn">▲ +${diff.toFixed(1)}%</span>`;
  if(diff < -2) return `<span class="trend-up">▼ ${diff.toFixed(1)}%</span>`;
  return `<span class="trend-ne">— ${diff>0?'+':''}${diff.toFixed(1)}%</span>`;
}
function show(id, el){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));
